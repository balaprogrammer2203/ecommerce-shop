PORT=5000

# MongoDB connection string, e.g. mongodb://localhost:27017
MONGO_URI=mongodb://localhost:27017
MONGO_DB_NAME=ecommerce

# JWT configuration
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Frontend URL for CORS
CLIENT_URL=http://localhost:5173

# NODE_ENV can be "development" or "production"
NODE_ENV=development

# Swagger access control
# - default: protected by auth middleware (`protect` + `admin`)
# - set to "true" to expose Swagger UI and OpenAPI spec publicly
SWAGGER_PUBLIC=false

# Stripe payments
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# PayPal payments
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_API_BASE_URL=https://api-m.sandbox.paypal.com

# Razorpay payments (India)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_CURRENCY=INR

